# ── Supabase ──────────────────────────────────────────────────────────────────
# Obtén estos valores en: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Aplicación ────────────────────────────────────────────────────────────────
# URL pública del sitio (sin barra final). Usado en emails y confirmaciones.
NEXT_PUBLIC_SITE_URL=https://4ustudioacademy.com

# ── Seguridad de Crons ────────────────────────────────────────────────────────
# Token secreto que Vercel envía al ejecutar los cron jobs.
# Generar con: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here
